<!DOCTYPE html>
<html lang="en">
<head>
    <script src='https://app.wotnot.io/chat-widget/3mKYzyKG48uW0716053458808ZYScUoz.js' defer></script>
    <meta charset="UTF-8">
    <title>Movie Recommendation Bot</title>
    <style>
        body {
            font-family: Arial;
            background: #111;
            color: #fff;
            text-align: center;
        }
        .container {
            margin-top: 50px;
        }
        select, button {
            padding: 10px;
            margin: 10px;
            font-size: 16px;
        }
        .result {
            margin-top: 20px;
            font-size: 18px;
            color: #00ffcc;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🎬 Movie Recommendation Bot</h1>

    <p>Select your favorite genre:</p>

    <select id="genre">
        <option value="action">Action</option>
        <option value="comedy">Comedy</option>
        <option value="romance">Romance</option>
        <option value="horror">Horror</option>
        <option value="thriller">Thriller</option>
    </select>

    <br>

    <button onclick="recommendMovie()">Recommend Movie</button>

    <div class="result" id="result"></div>
</div>

<script>
    function recommendMovie() {
        let genre = document.getElementById("genre").value;
        let movies = {
            action: ["Avengers: Endgame", "Mad Max: Fury Road", "John Wick"],
            comedy: ["The Mask", "Superbad", "3 Idiots"],
            romance: ["Titanic", "The Notebook", "La La Land"],
            horror: ["The Conjuring", "It", "Annabelle"],
            thriller: ["Inception", "Shutter Island", "Gone Girl"]
        };

        let randomMovie = movies[genre][Math.floor(Math.random() * movies[genre].length)];

        document.getElementById("result").innerHTML = "🎥 Recommended Movie: " + randomMovie;
    }
</script>

</body>
</html>